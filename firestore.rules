rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── assessments (existing) ───────────────────────────────────────────────
    match /assessments/{assessmentId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isAdmin(request.auth)
      );
      allow delete: if isAdmin(request.auth);
    }

    // ─── transactions ─────────────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.clientEmail == request.auth.token.email || isAdmin(request.auth)
      );
      allow delete: if isAdmin(request.auth);
    }

    // ─── clients ──────────────────────────────────────────────────────────────
    match /clients/{clientId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin(request.auth);

      match /assessments/{assessmentId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── vehicles ─────────────────────────────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.clientEmail == request.auth.token.email || isAdmin(request.auth)
      );
      allow delete: if isAdmin(request.auth);
    }

    // ─── towing_dispatches ────────────────────────────────────────────────────
    match /towing_dispatches/{dispatchId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin(request.auth);
    }

    // ─── reports_data ─────────────────────────────────────────────────────────
    match /reports_data/{reportId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin(request.auth);
    }

    // ─── admin space ──────────────────────────────────────────────────────────
    match /admin/{document=**} {
      allow read, write: if isAdmin(request.auth);
    }

    // ─── client_submissions (legacy) ──────────────────────────────────────────
    match /client_submissions/{docId} {
      allow create: if isSignedIn();
      allow get, update, delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow read, write: if isAdmin(request.auth);
    }

  }

  function isAdmin(auth) {
    return auth != null && (
      auth.token.admin == true ||
      auth.uid in ["UID_ADMIN_1", "UID_ADMIN_2"]
    );
  }

  function isSignedIn() {
    return request.auth != null;
  }
}
