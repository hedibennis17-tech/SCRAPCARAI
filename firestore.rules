rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // assessments — anyone signed in (incl. anonymous) can create
    match /assessments/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // transactions
    match /transactions/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // clients
    match /clients/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;

      match /assessments/{aid} {
        allow read, write: if request.auth != null;
      }
    }

    // vehicles
    match /vehicles/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // towing_dispatches
    match /towing_dispatches/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // reports_data
    match /reports_data/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // admin space
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    // client_submissions (legacy)
    match /client_submissions/{id} {
      allow read, write: if request.auth != null;
    }
  }

  function isAdmin() {
    return request.auth != null && (
      request.auth.token.admin == true ||
      request.auth.token.email == 'hedibennis17@gmail.com'
    );
  }
}
