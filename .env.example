# =============================
# SCRAP CAR AI — Variables d'environnement
# =============================
# Copie ce fichier en .env.local pour le développement local
# Sur Vercel : ajoute ces variables dans Project Settings > Environment Variables

# --- Google Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Email / SMTP (ex: Gmail, SendGrid, Mailgun) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_password_or_app_password
EMAIL_FROM=noreply@scrapcarai.com

# --- Admin ---
ADMIN_EMAIL=hedibennis17@gmail.com
